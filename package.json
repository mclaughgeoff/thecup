{
  "name": "cup-app",
  "version": "1.0.0",
  "description": "The Cup - Annual Ryder Cup Golf Trip App",
  "private": true,
  "scripts": {
    "dev": "prisma db push --accept-data-loss && next dev -H 0.0.0.0 -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "db:setup": "prisma db push && npm run prisma:seed"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "next": "^14.2.0",
    "@prisma/client": "^5.10.0",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "nodemailer": "^6.9.8",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "prisma": "^5.10.0",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/nodemailer": "^6.4.14",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0"
  }
}
